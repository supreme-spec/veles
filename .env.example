# Конфигурация для разработки
NEXT_PUBLIC_NODE_ENV=development

# URL приложения
NEXT_PUBLIC_APP_URL=http://localhost:3000

# TON Connect настройки
NEXT_PUBLIC_TON_MANIFEST_URL=http://localhost:3000/tonconnect-manifest.json

# Unsplash API для еженедельных фото
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
UNSPLASH_SECRET_KEY=your_unsplash_secret_key_here
UNSPLASH_APPLICATION_ID=your_unsplash_application_id_here

# SMTP настройки для отправки email
# Для Gmail: smtp.gmail.com, порт 587
# Для Yandex: smtp.yandex.ru, порт 587  
# Для Mail.ru: smtp.mail.ru, порт 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Настройки отладки
NEXT_PUBLIC_DEBUG=false

# Настройки аналитики (если используется)
NEXT_PUBLIC_ANALYTICS_ENABLED=false
