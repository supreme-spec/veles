{
  "name": "veles-voyage-next",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run build:llm && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "clean": "taskkill /f /im node.exe 2>nul & rmdir /s /q .next 2>nul",
    "clean-all": "taskkill /f /im node.exe 2>nul & rmdir /s /q .next 2>nul & rmdir /s /q node_modules 2>nul",
    "fresh": "npm run clean && npm run dev",
    "fresh-install": "npm run clean-all && npm install --legacy-peer-deps && npm run dev",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:api": "jest src/__tests__/api",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "analyze": "cross-env ANALYZE=true npm run build",
    "build:analyze": "npm run build && npx @next/bundle-analyzer",
    "measure": "node scripts/measure-performance.js",
    "check-bundle": "node scripts/check-bundle-size.js",
    "export": "next build && next export",
    "update:cities": "npx tsx scripts/update-cities.ts",
    "update:airports": "npx tsx scripts/update-airports.ts",
    "update:data": "npm run update:cities && npm run update:airports"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.1.1",
    "@heroicons/react": "^2.0.18",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^7.0.1",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "argon2": "^0.45.1",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.3",
    "critters": "^0.0.25",
    "encoding": "^0.1.13",
    "fast-xml-parser": "^5.10.1",
    "framer-motion": "^12.42.2",
    "gray-matter": "^4.0.3",
    "groq-sdk": "^1.3.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.25.0",
    "mapbox-gl": "^3.26.0",
    "next": "^14.2.0",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^9.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^5.0.0",
    "sqlite3": "^6.0.1",
    "web-push": "^3.6.7",
    "web-vitals": "^6.0.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.0",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/google.maps": "^3.58.1",
    "@types/jest": "^29.5.11",
    "@types/leaflet": "^1.9.21",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.50.0",
    "autoprefixer": "^10.4.15",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "icojs": "^0.19.5",
    "image-size": "^2.0.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.57.0",
    "postcss": "^8.4.28",
    "postcss-import": "^16.1.1",
    "postcss-nesting": "^13.0.2",
    "sharp": "^0.34.3",
    "tailwindcss": "^3.3.3",
    "to-ico": "^1.1.5",
    "ts-jest": "^29.1.1",
    "typescript": "^5.6.3",
    "zod": "^3.25.76"
  }
}
